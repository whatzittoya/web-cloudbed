{% extends 'layouts/base.html.twig' %}

{% block content %}
    <div class="space-y-6">
        <section class="rounded-[2rem] border border-slate-200 bg-white p-6 sm:p-8">
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-600">Welcome</p>
            <div class="mt-4 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
                <div>
                    <h2 class="text-3xl font-semibold text-slate-900">Hello, {{ auth.name }}</h2>
                    <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-500">
                        You have successfully signed in using your name and PIN. Access is limited to active employees.
                    </p>
                </div>
                <div class="rounded-[1.5rem] bg-slate-50 px-5 py-4">
                    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-400">Employee Code</p>
                    <p class="mt-2 text-lg font-semibold text-slate-900">{{ auth.code ?: 'N/A' }}</p>
                </div>
            </div>
        </section>

        <section class="grid gap-4 md:grid-cols-3">
            <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6">
                <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-400">Job Title</p>
                <p class="mt-3 text-lg font-semibold text-slate-900">{{ auth.jobTitle ?: 'Not set' }}</p>
            </article>
            <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6">
                <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-400">Email</p>
                <p class="mt-3 text-lg font-semibold text-slate-900">{{ auth.email ?: 'Not set' }}</p>
            </article>
            <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6">
                <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-400">Phone</p>
                <p class="mt-3 text-lg font-semibold text-slate-900">{{ auth.phone1 ?: 'Not set' }}</p>
            </article>
        </section>

        <section class="grid gap-4 lg:grid-cols-2">
            <article class="rounded-[2rem] border border-slate-200 bg-white p-6 sm:p-8">
                <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-600">Customer</p>
                <h3 class="mt-2 text-2xl font-semibold text-slate-900">Add Customer</h3>
                <p class="mt-3 text-sm leading-7 text-slate-500">
                    Search reservation guests and add them directly into the customer list.
                </p>
                <a href="{{ base_path }}/customers/add" class="mt-6 inline-flex items-center justify-center rounded-xl bg-sky-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sky-500">
                    Open add customer
                </a>
            </article>

            <section class="rounded-[2rem] border border-slate-200 bg-white p-6 sm:p-8">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                    <div>
                        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-600">Cloudbeds</p>
                        <h3 class="mt-2 text-2xl font-semibold text-slate-900">Reservations</h3>
                        <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-500">
                            Review checked-in reservations and sync the latest Cloudbeds records.
                        </p>
                    </div>
                    <a href="{{ base_path }}/reservations" class="inline-flex items-center justify-center rounded-xl bg-sky-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sky-500">
                        Open reservations
                    </a>
                </div>
            </section>
        </section>

        <section class="rounded-[2rem] border border-slate-200 bg-white p-6 sm:p-8">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-600">Payments</p>
                    <h3 class="mt-2 text-2xl font-semibold text-slate-900">Check Sales</h3>
                    <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-500">
                        Review payment rows with linked guest, room, reservation, and property details.
                    </p>
                </div>
                <a href="{{ base_path }}/payments" class="inline-flex items-center justify-center rounded-xl bg-sky-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sky-500">
                    Open payments
                </a>
            </div>
        </section>
    </div>
{% endblock %}
