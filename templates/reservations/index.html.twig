{% extends 'layouts/base.html.twig' %}

{% block content %}
    <div class="space-y-6">
        <section class="rounded-[2rem] border border-slate-200 bg-white p-6 sm:p-8">
            <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-600">Cloudbeds</p>
                    <h2 class="mt-2 text-3xl font-semibold text-slate-900">Reservations</h2>
                    <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-500">
                        Critical reservation info for checked-in guests synced from Cloudbeds.
                    </p>
                    <p class="mt-2 text-sm text-slate-500">
                        Last pulled:
                        <span class="font-medium text-slate-700">{{ last_pulled_at ?: 'Never' }}</span>
                    </p>
                </div>
                <div class="flex flex-col items-end gap-2">
                    <form id="pull-reservations-form" method="post" action="{{ base_path }}/reservations/pull">
                        <button
                            id="pull-reservations-button"
                            type="submit"
                            class="inline-flex items-center justify-center gap-3 rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-700 disabled:cursor-not-allowed disabled:bg-slate-400"
                        >
                            <span
                                id="pull-reservations-spinner"
                                class="hidden h-4 w-4 rounded-full border-2 border-white/30 border-t-white animate-spin"
                                aria-hidden="true"
                            ></span>
                            <span id="pull-reservations-label">Pull reservation from Cloudbeds</span>
                        </button>
                    </form>

                    <div class="flex items-center gap-2">
                        <button
                            id="scheduler-toggle"
                            type="button"
                            role="switch"
                            aria-checked="{{ scheduler.enabled ? 'true' : 'false' }}"
                            class="relative inline-flex h-5 w-9 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 focus:outline-none {{ scheduler.enabled ? 'bg-violet-600' : 'bg-slate-300' }}"
                        >
                            <span class="pointer-events-none inline-block h-4 w-4 transform rounded-full bg-white shadow transition duration-200 {{ scheduler.enabled ? 'translate-x-4' : 'translate-x-0' }}"></span>
                        </button>
                        <span class="text-xs text-slate-500">Auto-pull</span>

                        <div id="scheduler-select-wrap" class="{{ scheduler.enabled ? '' : 'hidden' }} flex items-center gap-1.5">
                            <span class="text-xs text-slate-300">·</span>
                            <select
                                id="scheduler-schedule"
                                class="rounded-lg border border-slate-200 bg-white py-1 pl-2 pr-6 text-xs text-slate-700 focus:border-violet-400 focus:outline-none"
                            >
                                <option value="every_5min" {{ scheduler.schedule == 'every_5min' ? 'selected' : '' }}>Every 5 min</option>
                                <option value="every_15min" {{ scheduler.schedule == 'every_15min' ? 'selected' : '' }}>Every 15 min</option>
                                <option value="every_30min" {{ scheduler.schedule == 'every_30min' ? 'selected' : '' }}>Every 30 min</option>
                                <option value="every_hour" {{ scheduler.schedule == 'every_hour' ? 'selected' : '' }}>Every hour</option>
                                <option value="every_2hours" {{ scheduler.schedule == 'every_2hours' ? 'selected' : '' }}>Every 2 hours</option>
                                <option value="every_6hours" {{ scheduler.schedule == 'every_6hours' ? 'selected' : '' }}>Every 6 hours</option>
                                <option value="every_12hours" {{ scheduler.schedule == 'every_12hours' ? 'selected' : '' }}>Every 12 hours</option>
                                <option value="daily" {{ scheduler.schedule starts with 'daily_' ? 'selected' : '' }}>Daily at…</option>
                            </select>
                            <input
                                id="scheduler-time"
                                type="time"
                                value="{{ scheduler.schedule starts with 'daily_' ? scheduler.schedule|slice(6) : '09:00' }}"
                                class="{{ scheduler.schedule starts with 'daily_' ? '' : 'hidden' }} rounded-lg border border-slate-200 bg-white py-1 px-2 text-xs text-slate-700 focus:border-violet-400 focus:outline-none"
                            >
                            <span id="scheduler-spinner" class="hidden h-3 w-3 rounded-full border-2 border-violet-300 border-t-violet-600 animate-spin"></span>
                        </div>
                    </div>
                    <div id="scheduler-feedback" class="hidden text-xs"></div>
                </div>
            </div>
            <div id="pull-reservations-feedback" class="mt-4 hidden rounded-2xl px-4 py-3 text-sm"></div>
        </section>

        <section class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white">
            {% if reservations %}
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-200">
                        <thead class="bg-slate-50">
                            <tr class="text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
                                <th class="px-6 py-4">Reservation</th>
                                <th class="px-6 py-4">Guest</th>
                                <th class="px-6 py-4">Stay</th>
                                <th class="px-6 py-4">Status</th>
                                <th class="px-6 py-4">Room Type</th>
                                <th class="px-6 py-4">Room Name</th>
                                <th class="px-6 py-4">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 text-sm text-slate-700">
                            {% for reservation in reservations %}
                                <tr data-reservation-id="{{ reservation.reservation_id }}">
                                    <td class="px-6 py-4 font-semibold text-slate-900">{{ reservation.reservation_id }}</td>
                                    <td class="px-6 py-4">{{ reservation.guest_name }}</td>
                                    <td class="px-6 py-4">{{ reservation.start_date }} to {{ reservation.end_date }}</td>
                                    <td class="px-6 py-4">
                                        <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.15em] text-emerald-700">
                                            {{ reservation.status|replace({'_': ' '}) }}
                                        </span>
                                    </td>
                                    <td class="px-6 py-4">{{ reservation.room_type_name ?: '-' }}</td>
                                    <td class="px-6 py-4">{{ reservation.room_name ?: '-' }}</td>
                                    <td class="px-6 py-4">
                                        <button
                                            type="button"
                                            class="reservation-add-customer inline-flex items-center justify-center gap-2 rounded-xl px-4 py-2 text-xs font-semibold transition {{ reservation.customer_added ? 'cursor-not-allowed bg-emerald-100 text-emerald-700' : 'bg-sky-600 text-white hover:bg-sky-500' }}"
                                            data-url="{{ base_path }}/reservations/{{ reservation.reservation_id }}/customers"
                                            {% if reservation.customer_added %}disabled{% endif %}
                                        >
                                            <span class="reservation-add-spinner hidden h-3.5 w-3.5 rounded-full border-2 border-white/30 border-t-white animate-spin"></span>
                                            <span class="reservation-add-label">{{ reservation.customer_added ? 'Added' : 'Add customer' }}</span>
                                        </button>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="px-6 py-12 text-center">
                    <p class="text-lg font-semibold text-slate-900">No reservations synced yet.</p>
                    <p class="mt-2 text-sm text-slate-500">Use the Cloudbeds pull button to fetch checked-in reservations.</p>
                </div>
            {% endif %}
        </section>
    </div>
{% endblock %}

{% block scripts %}
    <script>
        $(function () {
            const $form = $('#pull-reservations-form');
            const $button = $('#pull-reservations-button');
            const $spinner = $('#pull-reservations-spinner');
            const $label = $('#pull-reservations-label');
            const $feedback = $('#pull-reservations-feedback');
            const $rows = $('tr[data-reservation-id]');
            const defaultLabel = $label.text();

            $form.on('submit', function (event) {
                event.preventDefault();

                $button.prop('disabled', true);
                $spinner.removeClass('hidden');
                $label.text('Pulling reservations...');
                $feedback.addClass('hidden').removeClass('border border-emerald-200 border-rose-200 bg-emerald-50 bg-rose-50 text-emerald-700 text-rose-700').text('');

                $.ajax({
                    url: $form.attr('action'),
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                }).done(function (response) {
                    $feedback
                        .removeClass('hidden')
                        .addClass('border border-emerald-200 bg-emerald-50 text-emerald-700')
                        .text(response.message || 'Reservations synced successfully.');

                    window.setTimeout(function () {
                        window.location.reload();
                    }, 700);
                }).fail(function (xhr) {
                    const response = xhr.responseJSON || {};

                    $feedback
                        .removeClass('hidden')
                        .addClass('border border-rose-200 bg-rose-50 text-rose-700')
                        .text(response.message || 'Failed to sync reservations.');

                    $button.prop('disabled', false);
                    $spinner.addClass('hidden');
                    $label.text(defaultLabel);
                });
            });

            // Scheduler
            const $schedulerToggle   = $('#scheduler-toggle');
            const $schedulerWrap     = $('#scheduler-select-wrap');
            const $schedulerSchedule = $('#scheduler-schedule');
            const $schedulerTime     = $('#scheduler-time');
            const $schedulerSpinner  = $('#scheduler-spinner');
            const $schedulerFeedback = $('#scheduler-feedback');

            function schedulerPost(payload) {
                $schedulerToggle.prop('disabled', true);
                $schedulerSpinner.removeClass('hidden');
                $schedulerFeedback.addClass('hidden');

                $.ajax({
                    url: '{{ base_path }}/reservations/scheduler',
                    method: 'POST',
                    contentType: 'application/json',
                    headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                    data: JSON.stringify(payload),
                }).done(function (res) {
                    const enabled = !!res.data.enabled;
                    $schedulerToggle.attr('aria-checked', enabled ? 'true' : 'false')
                        .toggleClass('bg-violet-600', enabled).toggleClass('bg-slate-300', !enabled);
                    $schedulerToggle.find('span').toggleClass('translate-x-4', enabled).toggleClass('translate-x-0', !enabled);
                    $schedulerWrap.toggleClass('hidden', !enabled);
                    $schedulerFeedback.removeClass('hidden').removeClass('text-rose-500').addClass('text-violet-500').text(res.message);
                }).fail(function (xhr) {
                    $schedulerFeedback.removeClass('hidden').removeClass('text-violet-500').addClass('text-rose-500')
                        .text((xhr.responseJSON || {}).message || 'Failed.');
                }).always(function () {
                    $schedulerToggle.prop('disabled', false);
                    $schedulerSpinner.addClass('hidden');
                });
            }

            $schedulerToggle.on('click', function () {
                const isEnabled = $schedulerToggle.attr('aria-checked') === 'true';
                if (isEnabled) {
                    schedulerPost({ enabled: false });
                } else {
                    const schedule = $schedulerSchedule.val() === 'daily'
                        ? 'daily_' + ($schedulerTime.val() || '09:00')
                        : $schedulerSchedule.val();
                    schedulerPost({ enabled: true, schedule });
                }
            });

            $schedulerSchedule.on('change', function () {
                const isDaily = $(this).val() === 'daily';
                $schedulerTime.toggleClass('hidden', !isDaily);
                if (!isDaily) {
                    schedulerPost({ enabled: true, schedule: $(this).val() });
                }
            });

            $schedulerTime.on('change', function () {
                if ($schedulerTime.val()) {
                    schedulerPost({ enabled: true, schedule: 'daily_' + $schedulerTime.val() });
                }
            });

            $rows.on('click', '.reservation-add-customer', function () {
                const $actionButton = $(this);
                const $row = $actionButton.closest('tr');
                const $actionSpinner = $actionButton.find('.reservation-add-spinner');
                const $actionLabel = $actionButton.find('.reservation-add-label');

                if ($actionButton.prop('disabled')) {
                    return;
                }

                $actionButton.prop('disabled', true).removeClass('bg-sky-600 hover:bg-sky-500').addClass('bg-slate-400 text-white');
                $actionSpinner.removeClass('hidden');
                $actionLabel.text('Saving...');
                $feedback.addClass('hidden').removeClass('border border-emerald-200 border-rose-200 bg-emerald-50 bg-rose-50 text-emerald-700 text-rose-700').text('');

                $.ajax({
                    url: $actionButton.data('url'),
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                }).done(function (response) {
                    $actionSpinner.addClass('hidden');
                    $actionLabel.text('Added');
                    $actionButton.removeClass('bg-slate-400 text-white').addClass('bg-emerald-100 text-emerald-700 cursor-not-allowed');
                    $feedback
                        .removeClass('hidden')
                        .addClass('border border-emerald-200 bg-emerald-50 text-emerald-700')
                        .text(response.message || 'Customer saved.');
                    $row.addClass('bg-emerald-50/50');
                }).fail(function (xhr) {
                    const response = xhr.responseJSON || {};

                    $actionButton.prop('disabled', false).removeClass('bg-slate-400').addClass('bg-sky-600 text-white hover:bg-sky-500');
                    $actionSpinner.addClass('hidden');
                    $actionLabel.text('Add customer');
                    $feedback
                        .removeClass('hidden')
                        .addClass('border border-rose-200 bg-rose-50 text-rose-700')
                        .text(response.message || 'Failed to save customer.');
                });
            });
        });
    </script>
{% endblock %}
